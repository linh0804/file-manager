#!/bin/bash
set -e

INSTALL_DIR="/root/.local/share/file-manager-php"
TEMP_ZIP="$INSTALL_DIR/file-manager.zip"
PORT="12089"

apt update -qq
apt install -y curl unzip

mkdir -p "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR/src"

cd $INSTALL_DIR

systemctl stop file-manager-php.service 2>/dev/null || true

openssl req \
  -x509 \
  -newkey rsa:4096 \
  -sha256 \
  -nodes \
  -keyout cert.key \
  -out cert.crt \
  -days 3650 \
  -subj "/CN=localhost" \
  -addext "subjectAltName=DNS:localhost,IP:127.0.0.1"

cat > Caddyfile <<'EOF'
{
    frankenphp {
        num_threads 8
        max_threads 8
        max_requests 8000
    }

    servers {
        protocols h1 h2
    }

    https_port 12089
    auto_https off
}

:12089 {
    tls /root/.local/share/file-manager-php/cert.crt /root/.local/share/file-manager-php/cert.key
    root * /root/.local/share/file-manager-php/src

    php_server
}
EOF

curl -L "https://static.nightmare.top/app/file-manager-php/release.zip" -o "$TEMP_ZIP"
unzip -q -o "$TEMP_ZIP" -d "$INSTALL_DIR/src"

curl -L -o frankenphp https://github.com/php/frankenphp/releases/download/v1.12.4/frankenphp-linux-x86_64
chmod +x frankenphp

# ==================== SYSTEMD SERVICE ====================
SERVICE_FILE="/etc/systemd/system/file-manager-php.service"

cat <<EOF > "$SERVICE_FILE"
[Unit]
Description=File Manager PHP (FrankenPHP)
Documentation=https://frankenphp.dev
After=network.target network-online.target
Requires=network-online.target

[Service]
Type=notify
User=root
Group=root
WorkingDirectory=$INSTALL_DIR

ExecStart=$INSTALL_DIR/frankenphp run --config $INSTALL_DIR/Caddyfile
ExecReload=$INSTALL_DIR/frankenphp reload --config $INSTALL_DIR/Caddyfile --force
TimeoutStopSec=5s
LimitNOFILE=1048576

PrivateTmp=true
ProtectSystem=full
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE

StandardOutput=null
StandardError=null
StandardInput=null

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

echo "Đang thiết lập và khởi động service..."
systemctl daemon-reload
systemctl enable --now file-manager-php.service

echo ""
echo "=== Kiểm tra service ==="
systemctl status file-manager-php.service --no-pager

echo ""
echo "🌐 Truy cập: https://[IP_VPS]:$PORT"
